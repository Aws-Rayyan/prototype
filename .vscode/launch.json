{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (breakpoints)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "127.0.0.1", "--port", "8002"],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Backend: FastAPI + auto-reload (subprocess)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "127.0.0.1", "--port", "8002"],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Frontend: Vite dev server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend: Chrome (React — start Vite separately)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Full stack: API + Vite terminal",
      "configurations": ["Backend: FastAPI (breakpoints)", "Frontend: Vite dev server"],
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}
